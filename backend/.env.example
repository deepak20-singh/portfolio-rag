# Groq API key — get yours free at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model to use for chat responses
# Options: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Number of chunks to retrieve per query (3-6 is the sweet spot)
TOP_K=5
